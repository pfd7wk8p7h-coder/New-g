                print(f"\n📊 Last {len(echolocator.history)} measurements:")
                for i, d in enumerate(echolocator.history, 1):
                    print(f"  {i}: {d:.2f} m")
                avg = np.mean(echolocator.history)
                print(f"\n📈 Average: {avg:.2f} m")
            else:
                print("\n❌ No saved measurements")
                
        elif choice == '5':
            echolocator.is_calibrated = False
            echolocator.system_delay = 0.0
            print("\n🔄 Calibration reset")
            
        elif choice == '6':
            print("\n👋 Goodbye!")
            break
            
        else:
            print("\n❌ Invalid choice. Please try again.")

